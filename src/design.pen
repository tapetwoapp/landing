                  "children": [
                    {
                      "type": "text",
                      "id": "60e9o",
                      "name": "1. Introduction",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "1. Introduction",
                      "lineHeight": 1.2,
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "31khC",
                      "name": "TapeTwo (“we”, “our”, or “us”) respects your privacy. This Privacy Policy explains how we handle your information when you use the TapeTwo mobile application (the “App”) and our website (tapetwo.app) (collectively, the “Services”). By using our Services, you agree to the practices described in this Privacy Policy.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "TapeTwo (“we”, “our”, or “us”) respects your privacy. This Privacy Policy explains how we handle your information when you use the TapeTwo mobile application (the “App”) and our website (tapetwo.app) (collectively, the “Services”). By using our Services, you agree to the practices described in this Privacy Policy.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "ylcox",
