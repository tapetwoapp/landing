                  },
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "74evS",
                      "name": "1. Introduction",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 664,
                      "content": "1. Introduction",
                      "lineHeight": 1.2,
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "Tv4Os",
                      "name": "TapeTwo (“we”, “our”, or “us”) respects your privacy. This Privacy Policy explains how we handle your information when you use the TapeTwo mobile application (the “App”) and our website (tapetwo.app) (collectively, the “Services”). By using our Services, you agree to the practices described in this Privacy Policy.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 664,
                      "content": "TapeTwo (“we”, “our”, or “us”) respects your privacy. This Privacy Policy explains how we handle your information when you use the TapeTwo mobile application (the “App”) and our website (tapetwo.app) (collectively, the “Services”). By using our Services, you agree to the practices described in this Privacy Policy.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "UFrqd",
                  "name": "Frame 40",
                  "width": "fill_container",
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "SNnYL",
                      "name": "2. Data Collection and Use",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "2. Data Collection and Use",
                      "lineHeight": 1.2,
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "S3gKe",
                      "name": "2.1. In the App",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "2.1. In the App",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "Bq7an",
                      "name": "We do not collect, store, or share any personal data on our servers. All information you create within the App — including your movie collections, watch progress, and preferences — is stored locally on your device and is never transmitted to us or any third party.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We do not collect, store, or share any personal data on our servers.\nAll information you create within the App — including your movie collections, watch progress, and preferences — is stored locally on your device and is never transmitted to us or any third party.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "51SB3",
                      "name": "2.2. On the Website",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "2.2. On the Website",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "nEMWr",
                      "name": "When visiting our website, you may choose to subscribe to our newsletter or updates by providing your email address. We use your email address solely to send you news about new features, updates, or announcements related to TapeTwo. Your information is stored securely using a third-party email service provider (e.g. Mailchimp or a similar service), and you can unsubscribe at any time using the link included in each email. We do not sell, share, or rent your information to anyone.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "When visiting our website, you may choose to subscribe to our newsletter or updates by providing your email address.\nWe use your email address solely to send you news about new features, updates, or announcements related to TapeTwo.\nYour information is stored securely using a third-party email service provider (e.g. Mailchimp or a similar service), and you can unsubscribe at any time using the link included in each email.\nWe do not sell, share, or rent your information to anyone.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "MZ9aA",
                  "name": "Frame 34",
                  "width": 664,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "ujG8A",
                      "name": "3. iCloud Storage",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 664,
                      "content": "3. iCloud Storage",
                      "lineHeight": 1.2,
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "Y5E3Y",
                      "name": "If iCloud Backup or iCloud Drive is enabled on your device, iOS may automatically store a copy of the App’s data in your personal iCloud account. This process is entirely managed by Apple, and we do not have access to or control over that data. For more details, please refer to the Apple Privacy Policy.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 664,
                      "content": "If iCloud Backup or iCloud Drive is enabled on your device, iOS may automatically store a copy of the App’s data in your personal iCloud account.\nThis process is entirely managed by Apple, and we do not have access to or control over that data.\nFor more details, please refer to the Apple Privacy Policy.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
