                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "u0UuB",
                      "name": "All information you create in the App — including your collections, watch progress, and preferences — is stored locally on your device and is never transmitted to us or any third parties.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "All information you create in the App — including your collections, watch progress, and preferences — is stored locally on your device and is never transmitted to us or any third parties.",
