                  },
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "vcKLs",
                      "name": "2. Data Collection and Use",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "2. Data Collection and Use",
                      "lineHeight": 1.2,
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "XQx4c",
                      "name": "2.1. In the App",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "2.1. In the App",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "uslSG",
                      "name": "We do not collect, store, or share any personal data on our servers. All information you create within the App — including your movie collections, watch progress, and preferences — is stored locally on your device and is never transmitted to us or any third party.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We do not collect, store, or share any personal data on our servers.\nAll information you create within the App — including your movie collections, watch progress, and preferences — is stored locally on your device and is never transmitted to us or any third party.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "7AQmf",
                      "name": "2.2. On the Website",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "2.2. On the Website",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "uOXBt",
                      "name": "When visiting our website, you may choose to subscribe to our newsletter or updates by providing your email address. We use your email address solely to send you news about new features, updates, or announcements related to TapeTwo. Your information is stored securely using a third-party email service provider (e.g. Mailchimp or a similar service), and you can unsubscribe at any time using the link included in each email. We do not sell, share, or rent your information to anyone.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "When visiting our website, you may choose to subscribe to our newsletter or updates by providing your email address.\nWe use your email address solely to send you news about new features, updates, or announcements related to TapeTwo.\nYour information is stored securely using a third-party email service provider (e.g. Mailchimp or a similar service), and you can unsubscribe at any time using the link included in each email.\nWe do not sell, share, or rent your information to anyone.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "p1cFQ",
