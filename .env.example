# Vercel KV (Upstash Redis) — used for beta email list.
# Auto-populated when you link Vercel KV to the project.
# For local dev, pull with: vercel env pull .env
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend — used to send beta confirmation emails.
# Get from resend.com/api-keys.
# Sandbox: from onboarding@resend.dev (no DNS needed).
# Production: verify your domain in Resend, then update `from` in src/server/beta-signup.ts.
RESEND_API_KEY=
