# Google Sheets webhook for beta signup collection.
# Get SHEETS_WEBHOOK_URL from Apps Script Deploy → Web App URL.
# SHEETS_WEBHOOK_SECRET must match the SECRET constant inside your Apps Script.
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Origins allowed to call /api/beta-signup. Comma-separated. Optional — defaults to localhost + Vercel preview.
# ALLOWED_ORIGINS=https://tapetwo.app,https://www.tapetwo.app
